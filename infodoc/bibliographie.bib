	keywords = {Analytical models, business analysis, business data processing, business intelligence systems, common conceptual representation, Companies, competitive intelligence, conceptual level, conceptual multidimensional modeling, consistent integrated data repository, Context, data analysis, data integration, Data models, data relevance, data warehouse, data warehouses, Decision making, decision-making process, {DW}, high-level declarative language, linked open data, {LOD}, multidimensional cube design, multidimensional model, nonexpert users, specific modeling languages, Syntactics, unified business analyses, Unified Cube},
	file = {IEEE Xplore Abstract Record:/home/fabrice/Zotero/storage/YJY4P3R3/7549337.html:text/html;Version soumise:/home/fabrice/Zotero/storage/SAZ38S6A/Ravat et al. - 2016 - Designing multidimensional cubes from warehoused d.pdf:application/pdf}
