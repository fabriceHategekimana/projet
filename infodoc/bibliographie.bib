	keywords = {blended learning instruction, computer aided instruction, Context, data integration, Economics, educational content consumption, educational material design, face-to-face classrooms, interoperability, Licenses, linked data, linked-open-educational-resources-data approach, {OER}, Open Access, open data, Open Educational Resources, open systems, recommender systems, reuse, Software},
