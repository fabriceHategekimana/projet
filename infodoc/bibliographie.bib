	date = {2016-05},
	keywords = {Aggregates, data mining, data warehouses, data warehousing, {DW}, Europe, on-line analytical processing, Organizations, {QB}2OLAP, query language, query languages, {RDF} Data Cube vocabulary, Resource description framework, semantic Web, Semantics, Standards, Statistical Linked Open Data, {SW}, Vocabulary},
	file = {IEEE Xplore Abstract Record:/home/fabrice/Zotero/storage/WH5KFZ7B/7498341.html:text/html;Version soumise:/home/fabrice/Zotero/storage/8ZJDDYAR/Varga et al. - 2016 - QB2OLAP Enabling OLAP on Statistical Linked Open .pdf:application/pdf}
