@inproceedings{hosen_aggregation_2016,
	title = {Aggregation of open data information using linked data: Case study education and job vacancy data in Jakarta},
	doi = {10.1109/ICACSIS.2016.7872725},
	shorttitle = {Aggregation of open data information using linked data},
	abstract = {Availability and connectivity between data become an important factor in information processing. Distribution of Open Data has already gave contribution in providing data, but we still need to connect those data to create a useful solution. The objective of this research is to create web application prototype that can combine web scraping process, aggregation, and dashboard visualization by using Linked Data and Open Data technology. The case study that we used is education and job vacancy information in Jakarta. The main data source for education data taken from website http://data.jakarta.go.id, and data source for job vacancy data taken from http://jobstreet.co.id. Various features in this web application include data storage, query modification, auto update data, web scraping, and dashboard visualization. The benefits from this research are to show the relation between data using graphics visualization, and also give information to user or stakeholder about the relationship between educational information and job vacancy information in Jakarta.},
