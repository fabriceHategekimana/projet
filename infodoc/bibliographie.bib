	date = {2016-10},
	keywords = {Athens municipalities, Budget Data, cluster analysis, Clustering algorithms, data mining, Data mining, Data Mining, data models, Data models, data visualisation, Data visualization, descriptive measures, descriptive statistics, Europe municipalities, Fiscal Data, fiscal knowledge discovery, {KDD}, Knowledge discovery, Knowledge Discovery, knowledge discovery in databases, knowledge extraction, Linked Open Data, open budget data modelling, {OpenBudgets}.eu, pattern clustering, public finance, semantic Web, Semantic Web, statistics, Thessaloniki municipalities, Urban areas, visualizations},
