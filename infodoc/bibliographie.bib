	date = {2016-06},
	keywords = {classification dimensions, Electronic publishing, Encyclopedias, Internet, Knowledge based systems, Linked Open Data based similarity measure, {LOD} resources, {LOD}-based similarity measure, ontological dimensions, Ontologies, ontologies (artificial intelligence), pattern classification, property dimensions, Semantics},
	file = {IEEE Xplore Abstract Record:/home/fabrice/Zotero/storage/HVP4TSIZ/7536467.html:text/html;Version soumise:/home/fabrice/Zotero/storage/P9MHYZ88/Cheniki et al. - 2016 - LODS A Linked Open Data Based Similarity Measure.pdf:application/pdf}
}

